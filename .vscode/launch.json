{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug client",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/client"
    },
    {
      "name": "Debug Backend",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/backend",
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "PORT": "4000"
      },
      "showLog": true
    }
  ]
}
